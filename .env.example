# Comify AI Backend – Environment Variables
# Copy this file to .env and fill in the values

# ── HuggingFace Space (RECOMMENDED – no GPU/Colab needed) ──
# Calls IDM-VTON running on HuggingFace infrastructure for free.
# Set USE_HF_SPACE=false to disable and fall back to Colab/local.
USE_HF_SPACE=true
HF_SPACE_ID=yisol/IDM-VTON
HF_TOKEN=                        # optional – set for private spaces or higher rate limits

# ── Google Colab GPU endpoint (optional, used if HF Space is off) ──
# When set, heavy AI inference (IDM-VTON) is forwarded to Colab.
# Leave empty to use local MediaPipe + PIL compositing.
COLAB_ENDPOINT=

# ── n8n Webhook URL (optional) ──
# The backend will send event notifications here (fire-and-forget).
N8N_WEBHOOK_URL=

# ── Server port ──
PORT=8001
